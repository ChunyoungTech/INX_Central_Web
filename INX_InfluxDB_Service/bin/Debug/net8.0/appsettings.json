{
  // 用來分辨程式版本
  "Version": "1.0.0",
  // 每次從Historian取?個點的資料 (Parameters有限制)
  "Batch.Size": 90,
  // 每次從Historian取資料的間隔時間，單位為秒
  "Historian.Resolution": 3000,
  // 輸入Historian Server的所在時區，如: UTC+8則為8，UTC-8則為-8
  "Historian.TimeZone": 8,
  //資料庫上的 各廠(FAC) 名稱
  "FacID": "FAC08",
  //中央的 LoaderDB 名稱(FAC_Loader, FAC_Loader_TEST)
  "LoaderDBName": "FAC_Loader_TEST",
  //Runtime Live 要傳到中央的 LiveTable 名稱
  "LiveTableName": "FAC8_Historian_Live",
  // 資料庫連線資訊
  "ConnectionStrings": {
    //"SQL": "Data Source=chunyoung.asuscomm.com,4514;Initial Catalog=Runtime;User ID=sa;Password=7hunY@UNG;TrustServerCertificate=True;"
    //Historian 資料庫連線資訊
