    //中央  SQL資料庫
    "SQL1": "Data Source=192.168.66.5,11433;Initial Catalog=INX_WorkCheckingDB_TEST;User ID=sa;Password=7hunY@UNG;TrustServerCertificate=True;"
  },
  // InfluxDB資料庫連線資訊
  "InfluxDB": {
    "URL": "http://192.168.66.5:8086",
    "Token": "BkTLqSs_eRZVq6-f49OjhHr1jDox46-e_cYCZ0YDQbf_HBPQn1z_5pBQ-u0vNGw78o8nz0hG31uuHX9Fi_Jt5g==",
    "Org": "cy",
