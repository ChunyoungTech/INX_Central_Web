<configuration>
  <system.web>
    <httpHandlers>
      <add path="ChartImg.axd" verb="GET,HEAD,POST" type="System.Web.UI.DataVisualization.Charting.ChartHttpHandler, System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" validate="false" />
    </httpHandlers>
    <compilation targetFramework="4.7.2" />
    <pages>
      <controls>
        <add src="~/_uc/ucPager.ascx" tagName="Pager" tagPrefix="uc" />
        <add src="~/_uc/ucYesNo.ascx" tagName="YesNo" tagPrefix="uc" />
        <add src="~/_uc/ucDate.ascx" tagName="ucDate" tagPrefix="uc" />
        <add src="~/_uc/ucDept.ascx" tagName="ucDept" tagPrefix="uc" />
        <add tagPrefix="asp" namespace="System.Web.UI.DataVisualization.Charting" assembly="System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      </controls>
    </pages>
    <authentication mode="Forms" />
    <sessionState timeout="30" />
    <httpRuntime enableVersionHeader="false" maxRequestLength="20480" executionTimeout="300" />
    <trace enabled="false" localOnly="true" />
    <customErrors mode="RemoteOnly" redirectMode="ResponseRewrite" defaultRedirect="~/error/error.html" />
    <webServices>
      <protocols>
        <add name="HttpPost" />
      </protocols>
    </webServices>
  </system.web>
  <connectionStrings>
    <clear />
    <add connectionString="Data Source=192.168.66.5,11433;Initial Catalog=INX_WorkCheckingDB2;User ID=sa;Password=7hunY@UNG" name="Main" providerName="System.Data.SqlClient" />
