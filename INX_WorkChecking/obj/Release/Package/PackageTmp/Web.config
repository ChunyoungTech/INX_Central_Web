    <add connectionString="Data Source=114.35.232.251,4513;Initial Catalog=INX_WorkCheckingDB2;User ID=sa;Password=7hunY@UNG" name="INX4CDSS" providerName="System.Data.SqlClient" />
    <add connectionString="Data Source=114.35.232.251,4513;Initial Catalog=INX_WorkCheckingDB2;User ID=sa;Password=7hunY@UNG" name="INX4CDSA" providerName="System.Data.SqlClient" />
