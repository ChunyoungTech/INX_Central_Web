    <add connectionString="Data Source=114.35.232.251,4513;Initial Catalog=INX_WorkCheckingDB2;User ID=sa;Password=7hunY@UNG" name="Mapp" providerName="System.Data.SqlClient" />
    <add connectionString="Data Source=192.168.66.5,11433;Initial Catalog=InxCentralReport;User ID=sa;Password=7hunY@UNG" name="Report" providerName="System.Data.SqlClient" />
    <add connectionString="Data Source=192.168.66.5,11433;Initial Catalog=Vendor_FAC;User ID=sa;Password=7hunY@UNG" name="Vendor" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <system.webServer>
    <httpErrors errorMode="DetailedLocalOnly" />
    <defaultDocument>
      <files>
        <add value="login.aspx" />
        <add value="index.aspx" />
      </files>
    </defaultDocument>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20980000" />
      </requestFiltering>
    </security>
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
    <validation validateIntegratedModeConfiguration="false" />
    <handlers>
      <remove name="ChartImageHandler" />
      <add name="ChartImageHandler" preCondition="integratedMode" verb="GET,HEAD,POST" path="ChartImg.axd" type="System.Web.UI.DataVisualization.Charting.ChartHttpHandler, System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
    </handlers>
  </system.webServer>
  <appSettings>
    <add key="TemplatePath" value="C:\Projects\CYCloudReport\CYCloudReport\ReportTemplate\" />
    <add key="ChartImageHandler" value="storage=file;timeout=20;dir=c:\TempImageFiles\;" />
    <add key="checkAD" value="" />
    <add key="msgSend" value="" />
    <add key="mailhost" value="" />
    <add key="mailid" value="" />
    <add key="mailpw" value="" />
    <add key="Domain" value="bookoolin" />
    <add key="DoAuto" value="0" />
    <add key="DoMapp" value="0" />
    <add key="FileAllow" value=".xls|.xlsx|.xlt|.xlsm" />
    <add key="ReportStorePath" value="D:\CYCloudReport\ReportDownload\" />
    <add key="SyncValueExtCount" value="1" />
    <add key="DoCheckProject" value="1" />
    <!--DoCheckProject：是否啟動[自動資料檢核]，如是value填入1-->
    <add key="SyncMappSP" value="sp_syncMappData" />
    <!--每10秒同步Mapp資料，執行的SP sp_syncMappData，如果不執行 將value改空白-->
    <!--每3秒取回辨識結果的API路徑，如果不執行 將value改空白-->
    <!--<add key="RecognitionAuth" value="http://192.168.11.180:8000/si/sdk/recognition/authorization" />
    <add key="SyncRecognitionAuthInterval" value="0/10 * * ? * * *" />-->
    <!--辨識系統辨識結果查詢API，如不執行，value保留空白 http://192.168.11.181:8000/si/std/log/user/query  -->
    <add key="RecognitionAuth" value="" />
    <add key="SyncRecognitionAuthInterval" value="0/20 * * ? * * *" />
    <add key="WorkCheckInDeviceCheckIn" value="CHECKIN;REGISTER" />
    <add key="WorkCheckInDeviceCheckOut" value="CHECKIN;REGISTER" />
    <add key="WorkCheckInCode" value="Face Identify Pass" />
    <!--辨識系統-時間差設定，避免系統間時間誤差，如不輸入或輸入錯誤，預設為5分鐘-->
    <add key="RecognitionDiffMinutes" value="5" />
    <!--廠商資料同步至辨識系統API路徑，如不執行，value保留空白 http://192.168.11.181:8000/si/std/ -->
    <add key="RecognitionPath" value="" />
    <!--廠商資料同步至辨識系統API DeviceName-->
    <add key="DeviceName" value="CHECKIN,REGISTER,gas_1f" />
    <!--廠商資料同步至辨識系統API ResultLog 1 or 0-->
    <add key="ResultLog" value="0" />
    <!--廠商資料同步至辨識系統API Account-->
    <add key="RecognitionAccount" value="admin@tw.shuttle.com" />
    <!--廠商資料同步至辨識系統API Password-->
    <add key="RecognitionPassword" value="password" />
    <!--廠商施工管理 自動報到-->
    <add key="WorkAutoCheckIn" value="0" />
    <!--廠商施工管理 自動簽退-->
    <add key="WorkAutoCheckOut" value="0" />
    <!--廠商資料同步至辨識系統API MAC值 (依實際於[辨識系統管理平台] 設備的MAC-Address)-->
    <add key="RecognitionMAC" value="005056C00008" />
    <!--UpdateFFUPerformance：是否啟動[自動更新FFU妥善率]，如是value填入1-->
    <add key="enableStartupFFURegist" value="0" />
    <!--FFU 相關設定-->
    <!--UpdateFFUPerformance：是否啟動[自動更新FFU妥善率]，如是value填入1-->
    <add key="UpdateFFUPerformance" value="0" />
    <!--UpdateFFUPerformanceTimeString：時間設定格式 秒 分 時 ? * * *-->
    <!--秒 分 時 可用,分隔 如 0 1,10 7,15 ? * * * 為每天 7點1分 7點10分 15點1分 15點10分 都會觸發 ? * * *請保持不動 詳細用法可以搜尋 QUARTZ CRON-->
    <add key="UpdateFFUPerformanceTimeString" value="0 0 7,15,23 ? * * *" />
    <!--UploadFFUPerformance：是否啟動[自動上報FFU妥善率]，如是value填入1-->
    <add key="UploadFFUPerformance" value="0" />
    <add key="UploadFFUPerformanceTimeString" value="0 0 0,8,16 ? * * *" />
    <!--更新FFU資料 間隔 每小時-->
    <add key="FFUUpdate" value="1" />
    <add key="FFUUpdateTimeString" value="0 30 * ? * * *" />
    <add key="opcServerIp" value="127.0.0.1" />
    <add key="opcServerName" value="ArchestrA.FSGateway" />
    <add key="opcServerGroup" value="ffu_CF2" />
    <add key="opcUpdateRate" value="30000" />
    <add key="logPath" value="D:/CYCloudReport/" />
    <add key="oldFFUPerformanceTable" value="vOLDFFUEquipment" />
    <add key="ffuDebug" value="0" />
    <!--警報參數管理-->
    <add key="startAlarmUpdater" value="http://192.168.2.242/AlarmStatusUpdater/api/TagManager/StartUpdater" />
    <add key="stopAlarmUpdater" value="http://192.168.2.242/AlarmStatusUpdater/api/TagManager/StopUpdater" />
    <!--demo-->
    <add key="startOPCOnStart" value="0" />
    <!--更新tag資料-->
    <add key="ForceReadTag" value="0" />
    <add key="ForceReadTagTimeString" value="30 * * ? * * *" />
    <!--寫tag資料入DB-->
    <add key="WriteTag2DB" value="0" />
    <add key="WriteTag2DBTimeString" value="0 * * ? * * *" />
    <!--自動報表-->
    <add key="DemoDoAuto" value="0" />
    <!--授權檔路徑，已不使用-->
    <add key="LicPath" value="D:/CYLic/" />
    <!--五階報表MAPP發送時間-->
    <add key="WorkMappHour" value="14" />
    <add key="WorkMappMin" value="05" />
    <!--空調課五階報表MAPP發送時間-->
    <add key="HVACWorkMappHour" value="14" />
    <add key="HVACWorkMappMin" value="05" />
    <!--氣化課五階報表MAPP發送時間-->
    <add key="GASWorkMappHour" value="14" />
    <add key="GASWorkMappMin" value="05" />
    <!--水務課五階報表MAPP發送時間-->
    <add key="WATERWorkMappHour" value="14" />
    <add key="WATERWorkMappMin" value="05" />
    <!--電力課五階報表MAPP發送時間-->
    <add key="POWERWorkMappHour" value="14" />
    <add key="POWERWorkMappMin" value="05" />
    <!---->
    <add key="VendorLoginCheck" value="http://localhost:56777/Login/AuthWorkCheckin" />
    <!--MAPP發送-->
    <add key="DoMappSend" value="0" />
    <!--MAPP(地震壓降)-->
    <add key="DoMappEV" value="1" />
    <!--MAPP(同時發CIM WebApi)-->
    <add key="DoCimWebApi" value="1" />
    <!--MAPP隔離到期，未解隔通知-->
    <add key="DoMappDisableRemind" value="0" />
    <!--報表Tag授權數-->
    <add key="LicenseQty" value="1" />
    <!--啟動 signalR-->
    <add key="AutoSignal" value="1" />
    <!--定時連線本系統，避免所有Session Timeout，觸發Application_End事件-->
    <add key="KeepAliveURL" value="http://localhost:2181/KeepAlive.aspx" />
    <!-- 定時發送[施工管理報表] value="1"=>每天18:00執行-->
    <add key="DoWorkingReport" value="0" />
    <!-- 每小時[施工管理簽到退MAPP] value="1"=>每小時執行 -->
    <add key="DoWorkCheckHourMapp" value="1" />
    <!-- 自動登入，開發用，正式環境請勿加入 -->
    <add key="AutoLogin" value="1" />
    <!-- 是否為開發環境，正式環境請勿加入 -->
    <add key="IsDevelop" value="1" />
    <!-- 中央資訊[InfluxDB]URL-->
    <add key="InfluxDBURL" value="http://chunyoung.asuscomm.com:58086" />
    <!-- 中央資訊[LoaderDB] 自動匯入排程Cron，如不執行請空白-->
    <add key="ImportLoaderDB" value="5 12/30 * ? * * *" />
    <!-- 中央資訊[InfluxDB] 自動匯入排程Cron，如不執行請空白-->
    <add key="ImportInfluxDB" value="5 5/30 * ? * * *" />
  </appSettings>
